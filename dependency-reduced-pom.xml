    <git.commit.timestamp>1738420627</git.commit.timestamp>
    <git.ref>master</git.ref>
    <git.commit.short>e83c208</git.commit.short>
    <git.commit.timestamp.datetime>2025-02-01T14:37:07Z</git.commit.timestamp.datetime>
    <git.worktree>C:\Users\11877\Documents\GitHub\SlimeAE</git.worktree>
    <git.commit>e83c2082db47fe4aac455014703d2e9750538389</git.commit>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>
</project>
